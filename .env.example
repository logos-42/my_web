# GitHub OAuth App 配置
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# 管理员 GitHub 用户名
ADMIN_GITHUB_ID=your-github-username

# ==================== Tavily 配置 ====================
# 用于解析微信公众号等反爬虫网站
# 注册获取免费 API key: https://tavily.com
# 免费额度：每月 1000 次请求
TAVILY_API_KEY=your-tavily-api-key

# ==================== 数据库配置 ====================
# 选择数据库类型：supabase | kv | mysql | memory
DATABASE_PROVIDER=supabase

# Supabase 配置（DATABASE_PROVIDER=supabase 时使用）
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Vercel KV 配置（DATABASE_PROVIDER=kv 时使用）
KV_REST_API_URL=your-kv-rest-api-url
KV_REST_API_TOKEN=your-kv-rest-api-token

# MySQL 配置（DATABASE_PROVIDER=mysql 时使用）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=articles
MYSQL_USER=root
MYSQL_PASSWORD=your-password
